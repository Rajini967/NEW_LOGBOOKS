


## Example environment file (SAFE TO COMMIT)
## Copy to `.env` and fill with real values locally.

# Django
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration (one DB per site/deployment — use the credentials for THIS site only)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=New_Logbook
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=127.0.0.1
DB_PORT=5432

# SMTP configuration for password reset emails
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@example.com

# Frontend base URL used in password reset links
FRONTEND_BASE_URL=http://localhost:8080
