## Example environment file (SAFE TO COMMIT)
## Copy to `.env.local` (or `.env`) and fill with real values locally.
##
## Multi-site (3 DBs = 3 deployments): build or deploy the frontend once per site.
## Set VITE_API_URL to that site’s backend and set VITE_AUDIT_REPORT_CLIENT to that
## site’s legal header line. VITE_* values are inlined at build time — rebuild after any change.

VITE_API_URL=http://127.0.0.1:8000/api

## Report header (CLIENT line on PDFs and print views). Use exactly one line per deployment.
## Examples — uncomment the line that matches this deployment’s database/site:
# VITE_AUDIT_REPORT_CLIENT=M/s. DR. REDDY'S LABORATORIES LTD, FTO UNIT-09, VISAKHAPATNAM, AP
# VITE_AUDIT_REPORT_CLIENT=M/s. DR. REDDY'S LABORATORIES LTD, FTO UNIT-07, DUVVADA, AP
# VITE_AUDIT_REPORT_CLIENT=M/s. DR. REDDY'S LABORATORIES LTD, FTO UNIT-11, PYDIBHEEMAVARAM, AP

## Optional: override defaults used in PDFHeader and Reports print header
# VITE_AUDIT_REPORT_MANUFACTURED_BY=M/s. PRAJ HIPURITY SYSTEMS LIMITED
# VITE_AUDIT_REPORT_LOGO_LEFT=
# VITE_AUDIT_REPORT_LOGO_RIGHT=
# VITE_AUDIT_REPORT_LOGO_LEFT_LABEL=Dr.Reddy's
# VITE_AUDIT_REPORT_LOGO_RIGHT_LABEL=Praj HiPurity Systems
